# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── App authentication ─────────────────────────────────────────────────────────
# Protects the lock screen on both the Trading Platform and the Dealer Portal.
# Set a strong password before deploying. Never commit the real value.
APP_PASSWORD=change_me_before_deploy

# ─── Telegram alerts ────────────────────────────────────────────────────────────
# Optional. When set, every TradingView webhook alert fires a Telegram message.
# 1. Create a bot via @BotFather on Telegram → get TELEGRAM_BOT_TOKEN
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to find your TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── TradingView webhook ────────────────────────────────────────────────────────
# Secret token expected in ?token= or the X-Webhook-Token header on
# POST /api/webhooks/tradingview  and  GET /api/market/tv-alerts.
# Leave blank to disable authentication (not recommended for production).
TV_WEBHOOK_SECRET=change_me_before_deploy

# ─── AI agent ───────────────────────────────────────────────────────────────────
# Optional. When set, the Trading Platform AI Agent tab sends market context to
# Claude (claude-haiku) for an AI-generated institutional summary.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Market data providers ──────────────────────────────────────────────────────
# At least one key is required for live market quotes.
# The server falls back through providers automatically: Yahoo → FMP → Finnhub → Polygon.
# Sign up at the respective developer portals — all have free tiers.

FINNHUB_API_KEY=
FMP_API_KEY=
TWELVE_DATA_API_KEY=
POLYGON_API_KEY=
UNUSUAL_WHALES_API_KEY=
TRADIER_API_KEY=
